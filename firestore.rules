rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //
    // Collection: users/{userId}/courses
    // Document ID: {courseId} (e.g., '1bat', '2bat')
    // Fields:
    //   - inputData: string (required)
    //   - config: map (required)
    //   - lastUpdated: string (required, ISO date)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ctorric1@xtec.cat" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string);
    }

    function isValidCourseData(data) {
      return data.keys().hasAll(['inputData', 'config', 'lastUpdated']) &&
             data.inputData is string &&
             data.inputData.size() < 100000 && // 100KB limit for safety
             data.config is map &&
             data.lastUpdated is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /courses/{courseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidCourseData(request.resource.data);
        allow update: if isOwner(userId) && isValidCourseData(request.resource.data);
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
